# GoblinFTP — environment variable reference.

# ── Server ────────────────────────────────────────────────────────────────────
GFTP_PORT=8080
# Writable data directory (settings.json, local chunk staging, etc.).
GFTP_DATA_DIR=/app/data
# Path to settings.json (env still overrides values inside it).
GFTP_SETTINGS_PATH=/app/data/settings.json
# Browser tab / page title.
GFTP_PAGE_TITLE=GoblinFTP

# ── White-label / branding ────────────────────────────────────────────────────
# All optional; override the matching `branding` block in settings.json. Applied
# at runtime via /api/system/vars — no rebuild needed.
GFTP_APP_NAME=GoblinFTP
# Logo + favicon image URLs (shown in the header/login instead of the default
# icon). Absolute URLs or paths served by your reverse proxy.
#GFTP_LOGO_URL=
#GFTP_FAVICON_URL=
# Accent color as a hex value (#RGB or #RRGGBB) — recolors the whole theme.
#GFTP_PRIMARY_COLOR=#2563eb
# Login tagline override (otherwise the localized default is used).
#GFTP_TAGLINE=
# Hide the "<app name> <version>" footer attribution. Only "true" enables.
GFTP_HIDE_ATTRIBUTION=false

# ── Secrets ───────────────────────────────────────────────────────────────────
# Session cookie signing key. If unset, an ephemeral random key is generated and
# all sessions are invalidated on restart. Set it (32+ random bytes) in prod.
#GFTP_SESSION_SECRET=
# HMAC key for signed download tokens. Same auto-gen/restart caveat as above.
#GFTP_DOWNLOAD_TOKEN_SECRET=

# ── Login & sessions ──────────────────────────────────────────────────────────
# Session lifetime in seconds (default 2h).
GFTP_SESSION_TTL_SECS=7200
# Failed-login throttle: max attempts before cooldown, and cooldown length.
GFTP_LOGIN_MAX_ATTEMPTS=5
GFTP_LOGIN_COOLDOWN_SECS=300
# Hide the manual login form (e.g. SSO-only deployments). Only "true" enables.
GFTP_DISABLE_LOGIN_FORM=false
# Where to send users who hit the disabled login form (optional URL).
#GFTP_LOGIN_DISABLED_REDIRECT=

# ── SSO (one-time login links) ────────────────────────────────────────────────
# Only "true" enables. See examples/sso/README.md.
GFTP_SSO_ENABLED=false
#GFTP_SSO_SECRET=

# ── Uploads & chunking ────────────────────────────────────────────────────────
# Chunk size in bytes (default 5 MiB) and max parallel chunk uploads.
GFTP_CHUNK_SIZE=5242880
GFTP_MAX_CONCURRENT_UPLOADS=3

# ── Logging ───────────────────────────────────────────────────────────────────
# Level: debug|info|warn|error. Format: json|text. Stdout is always written.
GFTP_LOG_LEVEL=info
GFTP_LOG_FORMAT=json
# Browser-error forwarding to /api/log/frontend. Only "false" disables it.
GFTP_LOG_FRONTEND=true

# Optional rotating file sink (in addition to stdout). Set GFTP_LOG_FILE to a
# path to enable; the size/backups/age knobs then apply.
#GFTP_LOG_FILE=/app/data/gftp.log
GFTP_LOG_FILE_MAX_SIZE_MB=10
GFTP_LOG_FILE_MAX_BACKUPS=5
GFTP_LOG_FILE_MAX_AGE_DAYS=0

# ── Prometheus metrics ────────────────────────────────────────────────────────
GFTP_METRICS_ENABLED=false
GFTP_METRICS_PORT=9091

# ── Sentry (optional error tracking) ──────────────────────────────────────────
# Backend DSN; SPA DSN is baked into the build (NUXT_PUBLIC_SENTRY_DSN).
#GFTP_SENTRY_DSN=
#NUXT_PUBLIC_SENTRY_DSN=
#GFTP_SENTRY_ENVIRONMENT=production
GFTP_SENTRY_SAMPLE_RATE=0

# ── S3 chunk staging (optional; env-only, never in settings.json) ─────────────
GFTP_S3_ENABLED=false
#GFTP_S3_ENDPOINT=https://s3.example.com   # must include http:// or https://
#GFTP_S3_BUCKET=
#GFTP_S3_ACCESS_KEY=
#GFTP_S3_SECRET_KEY=
GFTP_S3_REGION=us-east-1
GFTP_S3_USE_PATH_STYLE=true
GFTP_S3_PREFIX=gftp-uploads
GFTP_S3_TIMEOUT_SECS=60

