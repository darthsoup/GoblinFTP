      "php", "phtml", "py", "rb", "go", "rs", "java", "c", "h", "cpp", "hpp",
      "sh", "bash", "zsh", "pl", "lua",
      "json", "json5", "xml", "svg", "yaml", "yml", "toml", "ini", "conf",
      "cfg", "env", "properties", "sql", "csv", "tsv",
